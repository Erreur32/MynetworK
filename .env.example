# MynetworK - Environment Variables

# JWT Secret for authentication tokens
# Minimum 32 characters recommended for production
# Faux secret pour exemple uniquement (ne pas utiliser en production)
JWT_SECRET=KiTvb6xPKUK6oRtf0pdKpGHel98xdXKw9ElLKaLEMjg=

# Optional: JWT expiration time (default: 7d)
# JWT_EXPIRES_IN=7d

# Optional: Server port (default: 3003 in development, 3000 in production)
# PORT=3003

# Optional: Timezone for Docker logs (default: Europe/Paris)
# Use standard tz database names: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
# TZ=Europe/Paris

# Optional: Freebox configuration
# FREEBOX_HOST=mafreebox.freebox.fr